# Vision LLM provider. Options:
#   gemini  — Google AI Studio Gemini API (requires GEMINI_API_KEY)
#   mock    — always return a clearly-labelled sample MTO (no API key needed)
# If you set VISION_PROVIDER=gemini but leave GEMINI_API_KEY empty, the app
# automatically falls back to 'mock' so it still runs end-to-end.
VISION_PROVIDER=gemini

# Google AI Studio API key. Get one at https://aistudio.google.com/apikey
# Leave blank to run in mock mode.
GEMINI_API_KEY=

# Gemini model to use. gemini-2.5-flash is fast and cheap; gemini-2.5-pro is
# more accurate but slower and costs more.
GEMINI_MODEL=gemini-2.5-flash

# Max upload size in MB. The server enforces this; the client also checks.
MAX_FILE_SIZE_MB=20

# Comma-separated list of allowed CORS origins (the Next.js dev server).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Where uploaded files are temporarily stored. Files are deleted after
# extraction completes.
UPLOAD_DIR=./_uploads
